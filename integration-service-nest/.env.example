# ── HTTP (health + metrics) ──────────────────────────────
HTTP_PORT=8090

# ── Kafka ────────────────────────────────────────────────
# Inside Docker use the internal listener (kafka:9092); from host use localhost:9094.
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=integration-service
KAFKA_GROUP_ID=integration-service-group

# ── MySQL (Source of Truth — core_business) ──────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=core_business
MYSQL_USER=app_user
MYSQL_PASSWORD=app_secret
