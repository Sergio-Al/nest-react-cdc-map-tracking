# ── HTTP (health + metrics) ──────────────────────────────
HTTP_PORT=8090

# ── Kafka ────────────────────────────────────────────────
# Inside Docker use the internal listener (kafka:9092); from host use localhost:9094.
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=integration-service
KAFKA_GROUP_ID=integration-service-group

# ── MySQL (Source of Truth — core_business) ──────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=core_business
MYSQL_USER=app_user
MYSQL_PASSWORD=app_secret

# ── Logging (Pino → stdout + rotating disk file at /app/logs) ─
# level: trace|debug|info|warn|error|fatal (defaults to info in Docker/prod)
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=integration-service.log
# rotate when a file reaches this size (k/m/g) OR every LOG_ROTATE_INTERVAL_MS…
LOG_MAX_SIZE=1m
# …whichever comes first. 259200000 ms = 3 days
LOG_ROTATE_INTERVAL_MS=259200000
# number of rotated files to keep (oldest auto-deleted past this)
LOG_RETAIN_COUNT=20
