# ==========================================================
# Streaming Tracking Logistic — Environment Variables
# ==========================================================
# Copy this file to .env before running:
#   cp .env.example .env
#
# Default values work for local development with Docker Compose.
# ==========================================================

# ── Application ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL (Source of Truth) ──────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=core_business
MYSQL_USER=app_user
MYSQL_PASSWORD=app_secret
MYSQL_ROOT_PASSWORD=root_secret

# ── PostgreSQL Cache DB ──────────────────────────────────
CACHE_DB_HOST=localhost
CACHE_DB_PORT=5432
CACHE_DB_NAME=tracking_cache
CACHE_DB_USER=tracking
CACHE_DB_PASSWORD=tracking_secret

# ── TimescaleDB ──────────────────────────────────────────
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=tracking_history
TIMESCALE_USER=timescale
TIMESCALE_PASSWORD=timescale_secret

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── Kafka ────────────────────────────────────────────────
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=tracking-service
KAFKA_GROUP_ID=tracking-service-group
KAFKA_EXTERNAL_PORT=9094

# ── App ──────────────────────────────────────────────────
# Deployment-default IANA timezone. Used as the system-default tenant timezone
# and as the bucket timezone for the driver_daily_stats continuous aggregate.
# Keep in sync with the literal in infrastructure/timescale/init/01-init.sql.
DEFAULT_TZ=America/La_Paz

# ── Logging (tracking-service, Pino → rotating disk file) ─
# level: trace|debug|info|warn|error|fatal (defaults to debug in dev, info in prod)
LOG_LEVEL=debug
# dir is relative to the tracking-service/ working directory
LOG_DIR=logs
LOG_FILE=tracking-service.log
# rotate when a file reaches this size (k/m/g) OR every LOG_ROTATE_INTERVAL_MS…
LOG_MAX_SIZE=1m
# …whichever comes first. 259200000 ms = 3 days
LOG_ROTATE_INTERVAL_MS=259200000
# number of rotated files to keep (oldest auto-deleted past this)
LOG_RETAIN_COUNT=20

# ── Auth (JWT) ───────────────────────────────────────────
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ── Traccar ──────────────────────────────────────────────
TRACCAR_API_KEY=traccar-shared-key
TRACCAR_PORT_API=8082
TRACCAR_PORT_TCP=5001
TRACCAR_PORT_UDP=5001
TRACCAR_DB_NAME=traccar
TRACCAR_DB_USER=traccar
TRACCAR_DB_PASSWORD=traccar_secret
# Traccar REST admin client (control-plane auto-provisions devices). tracking-service
# runs locally → localhost:8082. Set PROVISIONING_ENABLED=false to disable the sync.
TRACCAR_URL=http://localhost:8082
TRACCAR_ADMIN_EMAIL=admin@example.com
TRACCAR_ADMIN_PASSWORD=admin
TRACCAR_PROVISIONING_ENABLED=true

# ── Route Optimization ───────────────────────────────────
OSRM_URL=http://localhost:5003
OSRM_PORT=5003
OR_TOOLS_URL=http://localhost:5002
OR_TOOLS_PORT=5002

# ── Tracking Service (Docker) ───────────────────────────
TRACKING_SERVICE_PORT=3000

# ── Stripe Billing (optional) ───────────────────────────
# Leave empty in local dev — billing endpoints (/api/subscriptions/webhook,
# /checkout, /portal) then return 503. STRIPE_WEBHOOK_SECRET is the signing
# secret (whsec_…) shown by `stripe listen` or the Dashboard webhook endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Reverse-trial length and the plan granted during the trial.
TRIAL_DAYS=14
TRIAL_PLAN=growth
# Where Stripe redirects after Checkout / Billing Portal (frontend URLs).
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/settings?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/settings?checkout=cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/settings
